<header class="sticky top-0 z-50 bg-[#050507]/90 backdrop-blur-md border-b border-neutral-900 h-16 flex items-center justify-between px-6 sm:px-12 lg:px-16 transition-all duration-200">
  <div class="flex items-center gap-3">
    <a href="/" class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-center p-1 shrink-0">
        <img src="/favicon.svg" alt="Secura Logo" class="w-5.5 h-5.5 object-contain" />
      </div>
      <div class="flex flex-col">
        <div class="flex items-center gap-1.5">
          <span class="text-sm font-black tracking-widest text-white font-mono">SECURA</span>
          <span class="px-1.5 py-0.5 bg-neutral-900 text-neutral-400 border border-neutral-800 rounded text-[8px] font-mono font-bold uppercase tracking-widest">SaaS</span>
        </div>
      </div>
    </a>
  </div>
  
  <nav class="hidden md:flex items-center gap-6 text-xs font-semibold text-neutral-400 font-mono">
