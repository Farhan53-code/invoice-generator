---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Secura • Zero-Knowledge Support">
  <div class="min-h-screen bg-[#050507] text-neutral-200 selection:bg-cyan-500 selection:text-black flex flex-col justify-between">
    <Header />

    <div class="flex-1 relative">
      <!-- Grid Background overlay -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(6,182,212,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(6,182,212,0.03)_1px,transparent_1px)] bg-[size:32px_32px] opacity-40 pointer-events-none"></div>
      <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Content Container -->
      <div class="relative max-w-4xl mx-auto px-6 py-16 sm:py-24 z-10">
        
        <!-- Header back button -->
        <div class="mb-12">
          <a 
            href="/" 
            class="inline-flex items-center gap-2 text-xs font-mono text-cyan-400 hover:text-cyan-300 transition-colors uppercase tracking-wider group"
          >
            <span class="transform group-hover:-translate-x-1 transition-transform inline-block">&larr;</span>
            <span>Back to Home</span>
          </a>
        </div>

      <!-- Hero Header -->
      <div class="border-b border-neutral-900 pb-10 mb-12">
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-cyan-950/40 border border-cyan-500/30 text-[10px] font-mono font-bold uppercase tracking-widest text-cyan-400 mb-6 shadow-[0_0_15px_rgba(6,182,212,0.1)]">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
          <span>SUPPORT PORTAL</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-white mb-6 font-mono">
          CONTACT SECURA <span class="bg-gradient-to-r from-cyan-400 to-indigo-500 bg-clip-text text-transparent">SUPPORT</span>
        </h1>
        <p class="text-base text-neutral-400 leading-relaxed max-w-2xl">
          Have queries about zero-knowledge encryption schemes, API key security, or custom organization seats? Submit a cryptographically isolated ticket below.
        </p>
      </div>

      <!-- Grid containing Contact Form and Stats -->
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12 text-sm text-neutral-400 font-sans">
        
        <!-- Contact Form Container (3/5 columns) -->
        <div class="md:col-span-3 bg-[#0b0b0f] border border-neutral-900 p-6 sm:p-8 rounded-2xl relative">
          <h2 class="text-sm font-bold text-white font-mono uppercase tracking-widest text-cyan-400 mb-6">
            // SEND SECURE TICKET
          </h2>
          
          <form class="space-y-5" onsubmit="event.preventDefault(); alert('Your secure ticket has been queued. We will respond within the SLA threshold.');">
            <div>
              <label class="block font-mono text-[10px] uppercase text-neutral-450 mb-2 font-semibold">User Email Address</label>
              <input 
                type="email" 
                required
                placeholder="fa3327392@gmail.com" 
                class="w-full h-11 px-4 rounded-lg bg-neutral-950 border border-neutral-800 text-neutral-200 text-xs focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-all placeholder:text-neutral-600 font-mono"
              />
            </div>

            <div>
              <label class="block font-mono text-[10px] uppercase text-neutral-450 mb-2 font-semibold">Subject / Area of Concern</label>
              <select 
                class="w-full h-11 px-4 rounded-lg bg-neutral-950 border border-neutral-800 text-neutral-200 text-xs focus:border-cyan-500 outline-none transition-all font-mono"
              >
                <option>Encryption Keys & Security Bóveda</option>
                <option>Billing, Invoices & Pro Plans</option>
                <option>API & Custom Organization Integrations</option>
                <option>Other / Account Deletion</option>
              </select>
            </div>

            <div>
              <label class="block font-mono text-[10px] uppercase text-neutral-450 mb-2 font-semibold">Encrypted Message Payload</label>
              <textarea 
                rows="5" 
                required
                placeholder="Write your query here. Message is fully isolated inside our support queues..."
                class="w-full p-4 rounded-lg bg-neutral-950 border border-neutral-800 text-neutral-200 text-xs focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-all placeholder:text-neutral-600 leading-relaxed font-mono"
              ></textarea>
            </div>

            <button 
              type="submit"
              class="w-full h-11 bg-white text-black font-semibold text-xs rounded-lg hover:bg-neutral-100 transition-all font-mono uppercase tracking-wider cursor-pointer"
            >
              Dispatch Ticket
            </button>
          </form>
        </div>

        <!-- Stats and Channels (2/5 columns) -->
        <div class="md:col-span-2 space-y-8">
          <div>
            <h3 class="text-xs font-bold text-white font-mono uppercase tracking-wider mb-3">Live SLA Monitor</h3>
            <div class="border border-neutral-900 rounded-xl p-4 bg-neutral-950 space-y-3 font-mono text-xs">
              <div class="flex justify-between items-center pb-2 border-b border-neutral-900">
                <span class="text-neutral-500">Ticket Status:</span>
                <span class="text-green-400 font-bold flex items-center gap-1">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-ping"></span>
                  NORMAL
                </span>
              </div>
              <div class="flex justify-between items-center pb-2 border-b border-neutral-900">
                <span class="text-neutral-500">Avg response:</span>
                <span class="text-cyan-400 font-bold">&lt; 15 minutes</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-neutral-500">Current Queue:</span>
                <span class="text-neutral-300 font-bold">0 active tickets</span>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xs font-bold text-white font-mono uppercase tracking-wider mb-3">Direct Support Channels</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="text-cyan-400 font-mono text-xs mt-0.5">// 01</span>
                <div>
                  <h4 class="text-white font-bold text-xs uppercase font-mono">Developer Email Support</h4>
                  <p class="text-neutral-500 text-xs mt-0.5 font-mono">support@secura.com</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-cyan-400 font-mono text-xs mt-0.5">// 02</span>
                <div>
                  <h4 class="text-white font-bold text-xs uppercase font-mono">Enterprise SLA Hotline</h4>
                  <p class="text-neutral-500 text-xs mt-0.5 font-mono">+1 (800) SECURA-SLA</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-cyan-400 font-mono text-xs mt-0.5">// 03</span>
                <div>
                  <h4 class="text-white font-bold text-xs uppercase font-mono">Corporate Headquarters</h4>
                  <p class="text-neutral-500 text-xs mt-0.5 font-mono">101 Cryptography Road, Cyber City, CA 94016</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

      </div>

      <!-- Footer stamp -->
      <div class="border-t border-neutral-900 mt-16 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="text-[10px] font-mono text-neutral-600">SECURA SECURITY GATEWAY STATUS: OPERATIONAL</span>
        <span class="text-[10px] font-mono text-neutral-500">PGP Key ID: 0x98A1EF40</span>
      </div>

    </div>
  </div>
    
  <Footer />
</div>
</Layout>
