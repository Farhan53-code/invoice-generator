{
  "name": "invoice-generator",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --port 3000 --host 0.0.0.0 --force",
    "build": "astro build",
    "build:cf": "CLOUDFLARE=true astro build",
    "deploy:cf": "CLOUDFLARE=true astro build && wrangler deploy",
    "preview": "astro preview --port 3000 --host 0.0.0.0",
    "astro": "astro",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^4.2.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "astro": "^7.1.0",
    "firebase": "^12.16.0",
    "lucide-react": "^0.546.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  }
}
