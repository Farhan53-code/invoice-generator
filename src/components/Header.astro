  <div class="flex items-center gap-4">
    <a href="/login" class="text-xs font-semibold text-neutral-300 hover:text-white transition-all font-mono uppercase tracking-wider">Log In</a>
    <a href="/register" class="h-8.5 px-4 rounded-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold text-xs flex items-center justify-center transition-all shadow-sm font-mono uppercase tracking-wider">Sign Up</a>
  </div>
