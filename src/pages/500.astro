---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="500: Security Integrity Overload • Secura Security"
  description="A cryptographic server exception has been detected by the sandbox layer."
>
  <div class="min-h-screen bg-[#050507] text-neutral-200 selection:bg-cyan-500 selection:text-black flex flex-col justify-between overflow-x-hidden">
    <Header />
    
    <div class="flex-1 flex items-center justify-center py-16 px-6">
      <div class="max-w-xl w-full text-center relative">
        <!-- Ambient background glow -->
        <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-72 h-72 bg-amber-900/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-24 left-1/2 -translate-x-1/2 w-72 h-72 bg-red-900/10 rounded-full blur-3xl pointer-events-none"></div>

        <!-- 500 Cyber-Console -->
        <div class="relative bg-[#0d0d11]/80 backdrop-blur-md border border-neutral-900 rounded-2xl p-8 md:p-12 text-left shadow-2xl">
          <div class="flex items-center justify-between border-b border-neutral-900 pb-4 mb-6">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-amber-500/80 animate-pulse"></span>
              <span class="text-[10px] font-mono tracking-widest text-amber-400 font-bold uppercase">INTEGRITY_COMPROMISED</span>
            </div>
            <span class="text-[10px] font-mono text-neutral-500 font-medium">ERR_CODE: 0x1F4 (500)</span>
          </div>

          <h1 class="text-6xl md:text-7xl font-mono font-black text-white tracking-tighter mb-4 selection:bg-amber-500">
            500<span class="text-amber-500 animate-pulse">_</span>
          </h1>
          
          <h2 class="text-lg md:text-xl font-bold text-neutral-200 mb-4 font-mono uppercase tracking-wide">
            Server Integrity Overload
          </h2>
          
          <p class="text-sm text-neutral-400 leading-relaxed mb-8">
            An unexpected cryptographic buffer or backend node took too long to verify. Rest assured, your offline vaults and credentials remain completely safe under client-side keys.
          </p>

          <!-- Interactive Container Reboot Simulator -->
          <div class="bg-black/60 border border-neutral-900/80 rounded-lg p-4 font-mono text-[11px] mb-8 select-none">
            <div class="flex items-center justify-between text-neutral-500 border-b border-neutral-900/60 pb-2 mb-2">
              <span>SYSTEM DISPATCHER LOGS</span>
              <button id="reboot-btn" class="text-amber-400 hover:text-amber-300 transition-colors uppercase font-bold text-[10px] tracking-wider">
                [ REBOOT SECURE CONTROLLER ]
              </button>
            </div>
            <div id="reboot-logs" class="space-y-1.5 min-h-[100px] text-neutral-400">
              <div class="text-neutral-500">&gt; Process dispatcher exception caught in thread 0x47B...</div>
              <div class="text-red-400">&gt; Status: Cryptographic container took longer than 3000ms to resolve signature</div>
              <div class="text-yellow-400">&gt; Isolation status: Secure containers have isolated themselves to prevent leakage.</div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/" class="flex-1 h-11 rounded-xl bg-amber-600 hover:bg-amber-700 text-black font-mono text-xs font-bold uppercase tracking-wider flex items-center justify-center transition-all shadow-lg hover:shadow-amber-500/10">
              Go to Home Screen
            </a>
            <button onclick="window.location.reload();" class="flex-1 h-11 rounded-xl bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 hover:border-neutral-700 text-neutral-300 hover:text-white font-mono text-xs font-semibold uppercase tracking-wider flex items-center justify-center transition-all">
              Reload current sector
            </button>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </div>

  <script is:inline>
    const rebootBtn = document.getElementById('reboot-btn');
    const logsContainer = document.getElementById('reboot-logs');

    if (rebootBtn && logsContainer) {
      const phases = [
        "&gt; Terminating compromised threads...",
        "&gt; Reallocating zero-knowledge crypto-cores... <span class='text-green-400'>DONE</span>",
        "&gt; Restoring integrity from isolated offline vault...",
        "&gt; Resolving JWT and active session certificates...",
        "&gt; Standard verification loop active. <span class='text-green-400'>ALL SECURE</span>",
        "<span class='text-green-400'>&gt; System back to nominal performance. Please click reload to retry your transaction safely.</span>"
      ];

      let isRunning = false;

      rebootBtn.addEventListener('click', () => {
        if (isRunning) return;
        isRunning = true;
        rebootBtn.textContent = "[ REBOOTING... ]";
        rebootBtn.classList.add('opacity-50');

        logsContainer.innerHTML = "<div class='text-amber-400 animate-pulse'>&gt; Re-initializing security container sandbox...</div>";

        let currentIdx = 0;
        const interval = setInterval(() => {
          if (currentIdx < phases.length) {
            const div = document.createElement('div');
            div.innerHTML = phases[currentIdx];
            logsContainer.appendChild(div);
            // auto scroll
            logsContainer.scrollTop = logsContainer.scrollHeight;
            currentIdx++;
          } else {
            clearInterval(interval);
            isRunning = false;
            rebootBtn.textContent = "[ REBOOT SECURE CONTROLLER ]";
            rebootBtn.classList.remove('opacity-50');
          }
        }, 400);
      });
    }
  </script>
</Layout>
