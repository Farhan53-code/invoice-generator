---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="404: Resource Corrupted • Secura Security"
  description="The requested sector or document could not be located in the secure database."
>
  <div class="min-h-screen bg-[#050507] text-neutral-200 selection:bg-cyan-500 selection:text-black flex flex-col justify-between overflow-x-hidden">
    <Header />
    
    <div class="flex-1 flex items-center justify-center py-16 px-6">
      <div class="max-w-xl w-full text-center relative">
        <!-- Ambient background glow -->
        <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-72 h-72 bg-indigo-900/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-24 left-1/2 -translate-x-1/2 w-72 h-72 bg-cyan-900/10 rounded-full blur-3xl pointer-events-none"></div>

        <!-- 404 Cyber-Console -->
        <div class="relative bg-[#0d0d11]/80 backdrop-blur-md border border-neutral-900 rounded-2xl p-8 md:p-12 text-left shadow-2xl">
          <div class="flex items-center justify-between border-b border-neutral-900 pb-4 mb-6">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80 animate-pulse"></span>
              <span class="text-[10px] font-mono tracking-widest text-red-400 font-bold uppercase">SECTOR_NOT_FOUND</span>
            </div>
            <span class="text-[10px] font-mono text-neutral-500 font-medium">ERR_CODE: 0x194 (404)</span>
          </div>

          <h1 class="text-6xl md:text-7xl font-mono font-black text-white tracking-tighter mb-4 selection:bg-red-500">
            404<span class="text-red-500 animate-pulse">_</span>
          </h1>
          
          <h2 class="text-lg md:text-xl font-bold text-neutral-200 mb-4 font-mono uppercase tracking-wide">
            Cryptographic Node Missing
          </h2>
          
          <p class="text-sm text-neutral-400 leading-relaxed mb-8">
            The database segment you are searching for does not exist, was moved to an encrypted vault, or your decryption privileges have expired.
          </p>

          <!-- Interactive Cryptographic Diagnostics Terminal -->
          <div class="bg-black/60 border border-neutral-900/80 rounded-lg p-4 font-mono text-[11px] mb-8 select-none">
            <div class="flex items-center justify-between text-neutral-500 border-b border-neutral-900/60 pb-2 mb-2">
              <span>SECURITY DIAGNOSTICS</span>
              <button id="recheck-btn" class="text-cyan-400 hover:text-cyan-300 transition-colors uppercase font-bold text-[10px] tracking-wider">
                [ RE-RUN DIAGNOSTICS ]
              </button>
            </div>
            <div id="diagnostics-logs" class="space-y-1.5 min-h-[100px] text-neutral-400">
              <div class="text-neutral-500">&gt; Initializing diagnostics...</div>
              <div>&gt; Secura Core Engine <span class="text-green-400">[ONLINE]</span></div>
              <div class="text-red-400">&gt; Lookup for path: <span id="current-path" class="underline"></span> returned 0 hits</div>
              <div class="text-yellow-400">&gt; Status: Route segment unmapped</div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/" class="flex-1 h-11 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-mono text-xs font-semibold uppercase tracking-wider flex items-center justify-center transition-all shadow-lg hover:shadow-indigo-500/10">
              Return to Safe Sector
            </a>
            <a href="/dashboard" class="flex-1 h-11 rounded-xl bg-neutral-900 hover:bg-neutral-800 border border-neutral-800 hover:border-neutral-700 text-neutral-300 hover:text-white font-mono text-xs font-semibold uppercase tracking-wider flex items-center justify-center transition-all">
              Go to Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </div>

  <script is:inline>
    // Get current path to print dynamically
    const currentPathSpan = document.getElementById('current-path');
    if (currentPathSpan) {
      currentPathSpan.textContent = window.location.pathname;
    }

    const recheckBtn = document.getElementById('recheck-btn');
    const logsContainer = document.getElementById('diagnostics-logs');

    if (recheckBtn && logsContainer) {
      const phrases = [
        "&gt; Pinging database container node...",
        "&gt; Access token verification... <span class='text-green-400'>SUCCESS</span>",
        "&gt; Scanning network sockets for active leaks...",
        "&gt; Decryption protocols... <span class='text-indigo-400'>AES-GCM-256</span>",
        "&gt; Verifying checksum integrity...",
        "&gt; Core database synchronization: <span class='text-green-400'>100% SECURE</span>",
        "<span class='text-red-400'>&gt; WARNING: Host partition '" + window.location.pathname + "' remains unmapped.</span>",
        "&gt; Suggestion: Return to dashboard or contact Secura admin."
      ];

      let isRunning = false;

      recheckBtn.addEventListener('click', () => {
        if (isRunning) return;
        isRunning = true;
        recheckBtn.textContent = "[ RUNNING... ]";
        recheckBtn.classList.add('opacity-50');

        logsContainer.innerHTML = "<div class='text-cyan-400 animate-pulse'>&gt; Executing live systems audit...</div>";

        let currentIdx = 0;
        const interval = setInterval(() => {
          if (currentIdx < phrases.length) {
            const div = document.createElement('div');
            div.innerHTML = phrases[currentIdx];
            logsContainer.appendChild(div);
            // auto scroll
            logsContainer.scrollTop = logsContainer.scrollHeight;
            currentIdx++;
          } else {
            clearInterval(interval);
            isRunning = false;
            recheckBtn.textContent = "[ RE-RUN DIAGNOSTICS ]";
            recheckBtn.classList.remove('opacity-50');
          }
        }, 350);
      });
    }
  </script>
</Layout>
