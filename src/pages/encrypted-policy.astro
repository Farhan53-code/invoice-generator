---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Encrypted Policy • Secura Cryptography Suite">
  <div class="min-h-screen bg-[#050507] text-neutral-200 selection:bg-cyan-500 selection:text-black flex flex-col justify-between">
    <Header />

    <div class="flex-1 relative">
      <!-- Grid Background overlay -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(6,182,212,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(6,182,212,0.03)_1px,transparent_1px)] bg-[size:32px_32px] opacity-40 pointer-events-none"></div>
      <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Content Container -->
      <div class="relative max-w-4xl mx-auto px-6 py-16 sm:py-24 z-10">
        
        <!-- Header back button -->
        <div class="mb-12">
          <a 
            href="/" 
            class="inline-flex items-center gap-2 text-xs font-mono text-cyan-400 hover:text-cyan-300 transition-colors uppercase tracking-wider group"
          >
            <span class="transform group-hover:-translate-x-1 transition-transform inline-block">&larr;</span>
            <span>Back to Home</span>
          </a>
        </div>

      <!-- Hero Header -->
      <div class="border-b border-neutral-900 pb-10 mb-12">
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-cyan-950/40 border border-cyan-500/30 text-[10px] font-mono font-bold uppercase tracking-widest text-cyan-400 mb-6 shadow-[0_0_15px_rgba(6,182,212,0.1)]">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
          <span>CRYPTOGRAPHIC SPECIFICATION PROTOCOL</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-white mb-6 font-mono">
          ENCRYPTED POLICY
        </h1>
        <p class="text-xs font-mono text-neutral-500">
          AES-GCM-256 &bull; PBKDF2-HMAC-SHA256 &bull; Web Cryptography Standard
        </p>
      </div>

      <!-- Core Cryptographic Specifications -->
      <div class="space-y-10 text-sm text-neutral-400 leading-relaxed font-sans max-w-3xl">
        
        <div>
          <h2 class="text-md font-bold text-white font-mono uppercase tracking-wider mb-3">1. Architectural Zero-Knowledge Cryptography</h2>
          <p>
            Secura ensures that client passwords, invoices, and expense budgets are safeguarded using standard client-side encryption. We use the browser's built-in <strong>Web Cryptography API</strong>. Your plain text values are encrypted inside memory before the ciphertext is synced to your profile's cloud storage.
          </p>
        </div>

        <div>
          <h2 class="text-md font-bold text-white font-mono uppercase tracking-wider mb-3">2. Cryptographic Algorithm Details</h2>
          <ul class="space-y-4">
            <li class="bg-[#0b0b0f] border border-neutral-900 rounded-xl p-5 space-y-2">
              <strong class="text-white block font-mono text-xs uppercase tracking-wider text-cyan-400">// AES-GCM 256-Bit</strong>
              <p class="text-xs text-neutral-400">
                Advanced Encryption Standard in Galois/Counter Mode. AES-GCM provides both confidentiality and authenticated integrity verification (AEAD). Each database item uses a randomly generated 12-byte initialization vector (IV) to prevent frequency analysis attacks.
              </p>
            </li>
            <li class="bg-[#0b0b0f] border border-neutral-900 rounded-xl p-5 space-y-2">
              <strong class="text-white block font-mono text-xs uppercase tracking-wider text-indigo-400">// PBKDF2 with HMAC-SHA256</strong>
              <p class="text-xs text-neutral-400">
                To derive the symmetric encryption key from your Master Vault Password, Secura utilizes Password-Based Key Derivation Function 2 with 100,000 hashing iterations combined with a unique, cryptographically secure 16-byte salt, making offline brute-force attacks computationally infeasible.
              </p>
            </li>
          </ul>
        </div>

        <!-- INTERACTIVE CRYPTOGRAPHIC PLAYGROUND -->
        <div class="bg-[#0b0b0f] border border-neutral-900 rounded-2xl p-6 sm:p-8 space-y-6">
          <div class="border-b border-neutral-900 pb-4">
            <h3 class="text-sm font-bold text-white font-mono uppercase tracking-widest text-cyan-400 flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-ping"></span>
              Interactive Crypto-Stream Simulator
            </h3>
            <p class="text-xs text-neutral-500 mt-1">
              Input custom text below to see how our AES-GCM local cipher generates dynamic, salted ciphertexts instantly inside your browser RAM.
            </p>
          </div>

          <div class="space-y-4 font-mono text-xs">
            <div>
              <label class="block text-[10px] uppercase text-neutral-500 mb-2 font-semibold">Plain Text Payload</label>
              <input 
                id="plain-input"
                type="text" 
                value="fa3327392_confidential_invoice_records" 
                class="w-full h-11 px-4 rounded-lg bg-neutral-950 border border-neutral-800 text-neutral-200 focus:border-cyan-500 outline-none transition-all placeholder:text-neutral-600 font-mono"
              />
            </div>

            <div>
              <label class="block text-[10px] uppercase text-neutral-500 mb-2 font-semibold">Client Hashing Salt</label>
              <input 
                id="salt-input"
                type="text" 
                value="secura_salt_9x9" 
                class="w-full h-11 px-4 rounded-lg bg-neutral-950 border border-neutral-800 text-neutral-200 focus:border-cyan-500 outline-none transition-all placeholder:text-neutral-600 font-mono"
              />
            </div>

            <div class="pt-2">
              <label class="block text-[10px] uppercase text-neutral-500 mb-2 font-semibold">Simulated AES-GCM Ciphertext Stream</label>
              <div 
                id="cipher-output"
                class="w-full p-4 rounded-lg bg-neutral-950 border border-dashed border-neutral-850 text-cyan-400 font-bold break-all leading-normal text-xs"
              >
                Generating payload streams...
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Footer stamp -->
      <div class="border-t border-neutral-900 mt-16 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="text-[10px] font-mono text-neutral-600">SECURA LABS CRYPTO LABS &bull; SYSTEM VERSION v2.4.0</span>
        <span class="text-[10px] font-mono text-cyan-400">AEAD SYSTEM LOCKED</span>
      </div>

    </div>
  </div>

  <Footer />
</div>

  <!-- Client-side script to run the interactive hashing simulation -->
  <script is:inline>
    const plainInput = document.getElementById('plain-input');
    const saltInput = document.getElementById('salt-input');
    const cipherOutput = document.getElementById('cipher-output');

    function simulateCrypto() {
      if (!plainInput || !saltInput || !cipherOutput) return;
      const plain = plainInput.value || '';
      const salt = saltInput.value || '';
      
      if (!plain) {
        cipherOutput.textContent = 'Enter plaintext...';
        return;
      }

      // Simple stable hex encoder to simulate AES cipher stream visually
      let hash = 0;
      for (let i = 0; i < plain.length; i++) {
        hash = (hash << 5) - hash + plain.charCodeAt(i);
        hash = hash & hash;
      }
      
      let saltHash = 0;
      for (let i = 0; i < salt.length; i++) {
        saltHash = (saltHash << 5) - saltHash + salt.charCodeAt(i);
        saltHash = saltHash & saltHash;
      }

      const hexCombined = Math.abs(hash).toString(16).padStart(8, '0') + Math.abs(saltHash).toString(16).padStart(8, '0');
      const ivBytes = 'e1a39fbc82';
      const encryptedStream = `aes_gcm::256::[iv:${ivBytes}]::[tag:8f2a]::[payload:${hexCombined}d0c4f82a17b0ea9c63b]`;
      
      cipherOutput.textContent = encryptedStream;
    }

    if (plainInput && saltInput) {
      plainInput.addEventListener('input', simulateCrypto);
      saltInput.addEventListener('input', simulateCrypto);
      // Run once at load
      simulateCrypto();
    }
  </script>
</Layout>
